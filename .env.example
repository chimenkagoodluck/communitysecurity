# ===========================================================
# COMMUNITY SECURITY ALERT SYSTEM (CSSA) — CONFIGURATION
# I want you to copy this file to `.env` and fill in real values.
# ===========================================================

# --- Application ---
APP_NAME="Community Security Alert System"
APP_ENV=development
DEBUG=true
SECRET_KEY=please-change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database (SQLite file in ./data/) ---
DATABASE_URL=sqlite:///./data/cssa.db

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Demo region: SE Nigeria center (Owerri/Aba area) ---
MAP_CENTER_LAT=5.4836
MAP_CENTER_LON=7.0332
MAP_DEFAULT_ZOOM=8

# --- ML model thresholds ---
SPATIAL_CONFIDENCE_THRESHOLD=0.40
TEMPORAL_ANOMALY_THRESHOLD=0.55
FUSION_ALERT_THRESHOLD=0.55

# Fusion equation: T = α·S_spatial + β·S_temporal + γ·S_spatial·S_temporal
FUSION_ALPHA=0.45
FUSION_BETA=0.40
FUSION_GAMMA=0.15

# --- Frame sampling (frames per second to actually process) ---
INGEST_TARGET_FPS=3

# --- Hotspot clustering (DBSCAN) ---
HOTSPOT_EPS_METERS=300
HOTSPOT_MIN_SAMPLES=3
HOTSPOT_WINDOW_HOURS=6

# --- Alerts: SMTP (Gmail app password recommended) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Community Security Alert"
SMTP_FROM_EMAIL=
